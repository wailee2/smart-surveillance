# ── Smart Surveillance — Environment Configuration ─────────────────────────
# Copy this file to .env and adjust values for your environment.
# All settings have sensible defaults — only override what you need.

# ── Server ────────────────────────────────────────────────────────────────
APP_NAME="Smart Surveillance & Speed Detection"
DEBUG=false

# ── Paths ─────────────────────────────────────────────────────────────────
WEIGHTS_DIR=weights
UPLOAD_DIR=static/uploads
OUTPUT_DIR=static/outputs
SNAPSHOTS_DIR=static/outputs/snapshots

# ── Device ────────────────────────────────────────────────────────────────
# Leave blank to auto-detect (CPU if no CUDA, GPU if CUDA available).
# Force CPU:  DEVICE=cpu   CPU_MODE=true
# Force GPU:  DEVICE=cuda:0  CPU_MODE=false
# DEVICE=cpu
# CPU_MODE=true

# ── Model Weights ─────────────────────────────────────────────────────────
TRAFFIC_LIGHT_WEIGHTS=weights/traffic_light_best.pt
VEHICLE_WEIGHTS=weights/vehicle_best.pt
LICENSE_PLATE_WEIGHTS=weights/license_plate_best.pt

# ── Depth Model ───────────────────────────────────────────────────────────
DEPTH_MODEL_NAME=depth-anything/Depth-Anything-V2-Small-hf

# ── Detection ─────────────────────────────────────────────────────────────
CONF_THRESHOLD=0.4
IOU_THRESHOLD=0.5

# ── Speed & Tracking ──────────────────────────────────────────────────────
SPEED_LIMIT_KMH=50.0
MIN_TRAJ_POINTS=6
MIN_FLOW_PIXELS=1.5
SPEED_DISPLAY_DELTA_KMH=2.0

# ── Kalman Filter ─────────────────────────────────────────────────────────
KALMAN_PROCESS_NOISE=0.5
KALMAN_MEASUREMENT_NOISE=8.0
KALMAN_INITIAL_VARIANCE=10.0

# ── Frame Intervals (CPU is larger for performance) ───────────────────────
FRAME_INTERVAL_CPU=30
FRAME_INTERVAL_GPU=20
DEPTH_EVERY_N_CPU=40
DEPTH_EVERY_N_GPU=20

# ── OCR ───────────────────────────────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.4
OCR_DEBUG_LOGGING=false
